  test {verify ((compatibility decomposition of (“¤(A0)”: Unicode scalar)) is (“¤(20)”: Unicode scalars))}
  [
   English: This is not merely the Decomposition Mapping property from the the Unicode Character Database; it is the final result of applying the entire compatibility decomposition algorithm.
  ]
  [
   English: It applies the Hangul syllable decomposition algorithm.
  ]
  test {verify ((compatibility decomposition of (“¤(AC00)”: Unicode scalar)) is (“¤(1100)¤(1161)”: Unicode scalars))}
