     let (• haystack: Unicode text) be (“ ”)
     verify ((primary match for (“!”) in (haystack) beginning at (beginning of (haystack))) does not exist)
    }
   ]
   (
    English: primary match for (pattern: pattern) in (haystack: slice of (haystack)) beginning at (beginning: haystack boundary) according to use as literal pattern
   )
   optional (slice of (haystack))
   {
    let (• cursor in pattern: pattern boundary) start as (beginning of (pattern))
    let (• end of pattern: pattern boundary) be (end of (pattern))
    let (• cursor in haystack: haystack boundary) start as (beginning)
    let (• end of haystack: haystack boundary) be (end of (haystack))
    while ({
