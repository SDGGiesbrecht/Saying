extension
 use of (pattern) as literal pattern indexed by (pattern index) separated by (pattern boundary) in (haystack) as list of (element) indexed by (haystack index) separated by (haystack boundary)
 {
  action (clients)
   (
    English: matches for (pattern: pattern) in (haystack: slice of (haystack)) beginning at (beginning: haystack boundary) according to use as literal pattern
   )
   list of (slice of (haystack))
   {
    let (• list: list of (slice of (haystack))) start as (empty: list of (slice of (haystack)))
    if (primary match for (pattern) in (haystack) beginning at (beginning)) exists, unwrap it as (• match: slice of (haystack)), {
     append (match) to (↓ list)
    }
    ← list
   }

  action (clients)
   [
