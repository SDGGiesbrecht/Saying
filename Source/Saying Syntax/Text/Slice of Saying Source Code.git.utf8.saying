enumeration (clients)
 (
  English: slice of Saying source code
  Swift: SayingSourceCodeSlice
 )
 {
  case
   (
    English: writing
    Swift: writing
   )

  case
   (
    English: 8‐bit encoded Unicode
    Swift: utf8
   )
   slice of (Unicode segments)
 }

use (clients)
 general use of (slice of Saying source code)
 {
 }
